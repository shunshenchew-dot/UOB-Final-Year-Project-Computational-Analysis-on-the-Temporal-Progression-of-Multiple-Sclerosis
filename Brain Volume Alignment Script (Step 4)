def find_t1_pp(tf: Path) -> Path | None:
    for p in sorted(list(tf.rglob("*.nii")) + list(tf.rglob("*.nii.gz"))):
        n = p.name.lower()
        if "mprage" in n and "_pp" in n and "lesion" not in n: return p
    return None

def find_raw_macro(tf: Path) -> Path | None:
    for p in sorted(list(tf.rglob("*.nii")) + list(tf.rglob("*.nii.gz"))):
        n = p.name.lower()
        if "macro_t1space_filled" in n and "aligned" not in n and "resampled_brains" not in n: return p
    return None

def find_lesion_mask(tf: Path) -> Path | None:
    cands = sorted(list(tf.rglob("*.nii")) + list(tf.rglob("*.nii.gz")))
    priority = [p for p in cands if "lesion" in p.name.lower() and "mask" in p.name.lower()]
    return priority[0] if priority else next((p for p in cands if "lesion" in p.name.lower()), None)


