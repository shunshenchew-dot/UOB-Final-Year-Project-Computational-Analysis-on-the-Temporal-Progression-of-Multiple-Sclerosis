def compute_longitudinal_stats(df_source, split_name, rater_name=None):
    if split_name == "WHOLE_COHORT":
        d = df_source.copy()
    else:
        d = df_source[df_source["split"] == split_name].copy()

    if rater_name is not None and "rater" in d.columns:
        d = d[d["rater"] == rater_name].copy()

    region_stats = []

    for region in PLOT_REGION_ORDER:
        reg_data = d[d["region_name"] == region].copy()
        if reg_data.empty:
            continue

        patient_first_last_abs = []
        patient_first_last_pct = []

        abs_num, abs_den, pct_num, pct_den = 0.0, 0.0, 0.0, 0.0

        for subj in sort_subjects(reg_data["subject"].unique()):
            subj_data = reg_data[reg_data["subject"] == subj].sort_values("Scan_Number").copy()
            n_i = len(subj_data)
            if n_i < 2:
                continue

            vols = subj_data["overlap_mm3"].to_numpy(dtype=float)
            v_first = vols[0]
            v_last = vols[-1]

            patient_first_last_abs.append(v_last - v_first)

            if v_first > 0:
                patient_first_last_pct.append(((v_last - v_first) / v_first) * 100.0)

            if n_i >= 3:
                delta_abs = np.diff(vols)
                if len(delta_abs) >= 2:
                    s_abs_i = np.std(delta_abs, ddof=1)
                    w = n_i - 2
                    abs_num += w * (s_abs_i ** 2)
                    abs_den += w

            if n_i >= 3:
                delta_pct = []
                for j in range(len(vols) - 1):
                    if vols[j] > 0:
                        delta_pct.append(100.0 * (vols[j + 1] - vols[j]) / vols[j])

                if len(delta_pct) >= 2:
                    s_pct_i = np.std(delta_pct, ddof=1)
                    w = n_i - 2
                    pct_num += w * (s_pct_i ** 2)
                    pct_den += w

        region_stats.append({
            "SubRegion": region,
            "MD_abs": np.mean(patient_first_last_abs) if patient_first_last_abs else 0.0,
            "MD_pct": np.mean(patient_first_last_pct) if patient_first_last_pct else 0.0,
            "SD_pooled_abs": np.sqrt(abs_num / abs_den) if abs_den > 0 else 0.0,
            "SD_pooled_pct": np.sqrt(pct_num / pct_den) if pct_den > 0 else 0.0,
            "N_subjects_first_last_abs": len(patient_first_last_abs),
            "N_subjects_first_last_pct": len(patient_first_last_pct),
        })

    stats_df = pd.DataFrame(region_stats)
    if not stats_df.empty:
        stats_df = stats_df.set_index("SubRegion").reindex(PLOT_REGION_ORDER).reset_index()

    return stats_df

