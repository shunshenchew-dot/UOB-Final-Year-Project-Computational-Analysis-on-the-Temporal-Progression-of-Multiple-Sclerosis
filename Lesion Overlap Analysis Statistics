def plot_subject_time(subj, tp, include_background=False):
    d = df[(df["subject"] == subj) & (df["timepoint"] == tp)].copy()
    if d.empty:
        return

    d = d[d["region_name"] != "Other / Unclassified Labels"].copy()

    if not include_background:
        d = d[d["region_name"] != "Background"].copy()

    order = [x for x in PLOT_REGION_ORDER.copy() if x != "Other / Unclassified Labels"]
    if not include_background:
        order = [x for x in order if x != "Background"]

    piv = d.pivot_table(
        index="region_name",
        columns="rater",
        values="overlap_mm3",
        aggfunc="first"
    ).fillna(0)

    piv = piv.reindex(order)

    x = np.arange(len(piv.index))
    w = 0.42
    tick_labels = [short_label(x) for x in piv.index]

    plt.figure(figsize=(24, 10))
    plt.bar(x - w/2, piv.get("Expert_V1", 0), width=w, label="Expert V1", edgecolor="black")
    plt.bar(x + w/2, piv.get("Expert_V2", 0), width=w, label="Expert V2", edgecolor="black")

    plt.xticks(x, tick_labels, rotation=0, ha="center")
    plt.title(f"{subj} {tp} — Lesion overlap per region", pad=24)
    plt.ylabel("Lesion overlap\nvolume (mm³)", labelpad=15)
    plt.xlabel("Brain region", labelpad=15)

    plt.legend(frameon=False)
    plt.grid(axis="y", linestyle="--", alpha=0.7)
    plt.tight_layout(pad=2.0)

    plt.savefig(FIG_OTHER / f"{subj}_{tp}_overlap_mm3_V1_vs_V2.png", dpi=300, bbox_inches="tight", pad_inches=0.2)
    plt.close()

