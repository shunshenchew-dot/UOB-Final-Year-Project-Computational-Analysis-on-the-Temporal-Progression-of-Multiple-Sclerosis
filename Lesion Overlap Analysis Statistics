def compute_total_lesion_stats(df_source, split_name):
    d = df_source.copy() if split_name == "WHOLE_COHORT" else df_source[df_source["split"] == split_name].copy()
    if d.empty:
        return None

    patient_v_first = []
    patient_v_last = []
    patient_first_last_abs = []
    patient_first_last_pct = []

    abs_num, abs_den, pct_num, pct_den = 0.0, 0.0, 0.0, 0.0

    for subj in sort_subjects(d["subject"].unique()):
        subj_data = d[d["subject"] == subj].sort_values("Scan_Number").copy()
        n_i = len(subj_data)
        if n_i < 2:
            continue

        vols = subj_data["total_lesion_mm3"].to_numpy(dtype=float)
        v_first = vols[0]
        v_last = vols[-1]

        patient_v_first.append(v_first)
        patient_v_last.append(v_last)

        patient_first_last_abs.append(v_last - v_first)
        if v_first > 0:
            patient_first_last_pct.append(((v_last - v_first) / v_first) * 100.0)

        if n_i >= 3:
            delta_abs = np.diff(vols)
            if len(delta_abs) >= 2:
                s_abs_i = np.std(delta_abs, ddof=1)
                w = n_i - 2
                abs_num += w * (s_abs_i ** 2)
                abs_den += w

            delta_pct = []
            for j in range(len(vols) - 1):
                if vols[j] > 0:
                    delta_pct.append(100.0 * (vols[j + 1] - vols[j]) / vols[j])

            if len(delta_pct) >= 2:
                s_pct_i = np.std(delta_pct, ddof=1)
                w = n_i - 2
                pct_num += w * (s_pct_i ** 2)
                pct_den += w

    return {
        "Metric": [
            "Initial Volume (Vi)",
            "Final Volume (Vf)",
            "Mean Abs Change (MD_abs)",
            "Mean Pct Change (MD_%)",
            "Pooled SD Abs (SD_pooled_abs)",
            "Pooled SD Pct (SD_pooled_%)"
        ],
        split_name: [
            round(np.mean(patient_v_first), 2) if patient_v_first else 0.0,
            round(np.mean(patient_v_last), 2) if patient_v_last else 0.0,
            round(np.mean(patient_first_last_abs), 2) if patient_first_last_abs else 0.0,
            round(np.mean(patient_first_last_pct), 2) if patient_first_last_pct else 0.0,
            round(np.sqrt(abs_num / abs_den), 2) if abs_den > 0 else 0.0,
            round(np.sqrt(pct_num / pct_den), 2) if pct_den > 0 else 0.0
        ]
    }

