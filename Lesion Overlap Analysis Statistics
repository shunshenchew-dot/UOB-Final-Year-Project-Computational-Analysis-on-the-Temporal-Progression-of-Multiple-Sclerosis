def pick_first(paths):
    paths = sorted(list(paths))
    return paths[0] if paths else None

def find_macro(time_dir: Path):
    cands = list(time_dir.rglob("resampled_fill.nii*"))
    if not cands:
        cands = list(time_dir.rglob("macro10.nii*"))
    return pick_first(cands)

def find_v1_v2_lesions(time_dir: Path):
    cands = [
        p for p in time_dir.rglob("*")
        if p.is_file()
        and "lesion" in p.name.lower()
        and not p.name.endswith(".txt")
    ]
    v1 = [p for p in cands if "v1" in p.name.lower()]
    v2 = [p for p in cands if "v2" in p.name.lower()]
    return (pick_first(v1), pick_first(v2), cands)

def load_img(p: Path):
    try:
        return sitk.ReadImage(str(p))
    except Exception as e:
        raise RuntimeError(f"FAILED to read: {p}\nReason: {e}")

def get_subject_number(subject_name: str):
    m = re.search(r"(\d+)", str(subject_name))
    return int(m.group(1)) if m else None

def get_split_from_subject(subject_name: str):
    n = get_subject_number(subject_name)
    if n is None:
        return "UNKNOWN"
    if 1 <= n <= 5:
        return "TRAIN"
    if 6 <= n <= 19:
        return "TEST"
    return "UNKNOWN"

def short_label(name: str):
    return DISPLAY_LABEL_MAP.get(name, name)

def sort_subjects(subjects):
    return sorted(subjects, key=lambda x: int(re.search(r"\d+", str(x)).group()))

def match_grid(img_to_change, reference_img):
    if (
        img_to_change.GetSize() == reference_img.GetSize()
        and img_to_change.GetSpacing() == reference_img.GetSpacing()
        and img_to_change.GetOrigin() == reference_img.GetOrigin()
        and img_to_change.GetDirection() == reference_img.GetDirection()
    ):
        return img_to_change

    resampler = sitk.ResampleImageFilter()
    resampler.SetReferenceImage(reference_img)
    resampler.SetInterpolator(sitk.sitkNearestNeighbor)
    resampler.SetDefaultPixelValue(0)
    resampler.SetTransform(sitk.Transform())
    return resampler.Execute(img_to_change)

def get_lesion_label_distribution(region_img, lesion_img):
    R = sitk.GetArrayFromImage(region_img).astype(np.int32)
    L = (sitk.GetArrayFromImage(lesion_img) > 0).astype(np.uint8)

    lesion_labels, counts = np.unique(R[L == 1], return_counts=True)
    total = int(counts.sum())

    rows = []
    for lab, c in zip(lesion_labels, counts):
        if 0 <= int(lab) <= 10:
            name = MACRO_LABEL_MAP[int(lab)]
        else:
            name = "Other / Unclassified Labels"

        pct = (100.0 * int(c) / total) if total > 0 else 0.0

        rows.append({
            "label_value": int(lab),
            "label_name": name,
            "lesion_voxels": int(c),
            "pct_of_total_lesion_voxels": pct,
        })
    return rows

def compute_overlap_rows(region_img, lesion_img):
    R = sitk.GetArrayFromImage(region_img).astype(np.int32)
    L = (sitk.GetArrayFromImage(lesion_img) > 0).astype(np.uint8)

    voxel_vol_mm3 = float(np.prod(region_img.GetSpacing()))
    total_lesion_voxels = int(L.sum())
    total_lesion_mm3 = float(total_lesion_voxels) * voxel_vol_mm3

    rows = []

    for label in range(0, 11):
        region_mask = (R == label)
        region_voxels = int(region_mask.sum())
        region_mm3 = float(region_voxels) * voxel_vol_mm3

        overlap_voxels = int(((L == 1) & region_mask).sum())
        overlap_mm3 = float(overlap_voxels) * voxel_vol_mm3

        pct_region_lesioned = (100.0 * overlap_mm3 / region_mm3) if region_mm3 > 0 else 0.0
        pct_lesion_in_region = (100.0 * overlap_mm3 / total_lesion_mm3) if total_lesion_mm3 > 0 else 0.0

        rows.append({
            "region_label": label,
            "region_name": MACRO_LABEL_MAP[label],
            "region_voxels": region_voxels,
            "region_vol_mm3": region_mm3,
            "overlap_voxels": overlap_voxels,
            "overlap_mm3": overlap_mm3,
            "pct_region_lesioned": pct_region_lesioned,
            "pct_lesion_in_region": pct_lesion_in_region,
            "total_lesion_voxels": total_lesion_voxels,
            "total_lesion_mm3": total_lesion_mm3,
        })

    valid_mask = np.isin(R, np.arange(0, 11))
    other_mask = ~valid_mask

    other_region_voxels = int(other_mask.sum())
    other_region_mm3 = float(other_region_voxels) * voxel_vol_mm3

    other_overlap_voxels = int(((L == 1) & other_mask).sum())
    other_overlap_mm3 = float(other_overlap_voxels) * voxel_vol_mm3

    pct_region_lesioned_other = (
        100.0 * other_overlap_mm3 / other_region_mm3
        if other_region_mm3 > 0 else 0.0
    )
    pct_lesion_in_region_other = (
        100.0 * other_overlap_mm3 / total_lesion_mm3
        if total_lesion_mm3 > 0 else 0.0
    )

    rows.append({
        "region_label": -1,
        "region_name": "Other / Unclassified Labels",
        "region_voxels": other_region_voxels,
        "region_vol_mm3": other_region_mm3,
        "overlap_voxels": other_overlap_voxels,
        "overlap_mm3": other_overlap_mm3,
        "pct_region_lesioned": pct_region_lesioned_other,
        "pct_lesion_in_region": pct_lesion_in_region_other,
        "total_lesion_voxels": total_lesion_voxels,
        "total_lesion_mm3": total_lesion_mm3,
    })

    return rows

