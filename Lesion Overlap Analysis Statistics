def plot_consensus_linegraphs(df_source, split_name, display_split, outname):
    if split_name == "WHOLE_COHORT":
        d = df_source.copy()
    else:
        d = df_source[df_source["split"] == split_name].copy()

    if d.empty:
        return

    region_fluctuations = d.groupby("region_name")["overlap_mm3"].std().fillna(0).sort_values(ascending=False)
    sorted_regions = [r for r in region_fluctuations.index.tolist() if (r in PLOT_REGION_ORDER and r != "Background")]

    n_regions = len(sorted_regions)
    ncols = 2
    nrows = math.ceil(n_regions / ncols)

    fig, axes = plt.subplots(nrows, ncols, figsize=(28, 10.0 * nrows), sharex=False)
    axes = np.array(axes).reshape(-1)

    subjects = sort_subjects(d["subject"].unique())
    colors = plt.cm.tab20(np.linspace(0, 1, len(subjects)))
    subj_color_map = dict(zip(subjects, colors))

    col_major_indices = []
    for col in range(ncols):
        for row in range(nrows):
            idx = row * ncols + col
            if idx < len(axes):
                col_major_indices.append(idx)

    plotted_axes = []

    global_scan_min = int(d["Scan_Number"].min())
    global_scan_max = int(d["Scan_Number"].max())
    xticks_int = list(range(global_scan_min, global_scan_max + 1))

    for i, region in enumerate(sorted_regions):
        ax_idx = col_major_indices[i]
        ax = axes[ax_idx]
        plotted_axes.append(ax_idx)

        reg_data = d[d["region_name"] == region].copy()

        for subj in subjects:
            subset = reg_data[reg_data["subject"] == subj].sort_values("Scan_Number")
            if subset.empty:
                continue

            ax.plot(
                subset["Scan_Number"],
                subset["overlap_mm3"],
                linestyle='-',
                marker='o',
                color=subj_color_map[subj],
                alpha=0.8,
                linewidth=3.0,
                markersize=10,
                label=subj
            )

        ax.set_title(short_label(region).replace('\n', ' '), pad=24)
        ax.set_xlabel("Scan number", labelpad=15)
        ax.set_ylabel("Lesion volume\n(mm$^3$)", labelpad=15)
        ax.tick_params(axis="x", labelsize=24)
        ax.tick_params(axis="y", labelsize=24)
        ax.grid(True, linestyle="--", alpha=0.4)

        ax.set_xticks(xticks_int)
        ax.xaxis.set_major_locator(MaxNLocator(integer=True))
        ax.xaxis.set_major_formatter(FormatStrFormatter('%d'))

    for k in range(len(axes)):
        if k not in plotted_axes:
            fig.delaxes(axes[k])

    plt.suptitle(
        f"Longitudinal Lesion Volume by Region ({display_split} Set - Consensus Average)",
        fontsize=42,
        fontweight="bold",
        y=0.995
    )

    handles, labels = [], []
    seen = set()
    for ax_idx in plotted_axes:
        h, l = axes[ax_idx].get_legend_handles_labels()
        for hh, ll in zip(h, l):
            if ll not in seen:
                handles.append(hh)
                labels.append(ll)
                seen.add(ll)

    if handles:
        ncol_legend = 5 if len(labels) >= 10 else max(1, len(labels))
        fig.legend(handles, labels, loc="upper center", bbox_to_anchor=(0.5, 0.975), ncol=ncol_legend)

    plt.tight_layout(rect=[0, 0, 1, 0.96], pad=3.0)
    plt.savefig(FIG_ESSENTIAL / outname, dpi=300, bbox_inches="tight", pad_inches=0.2)
    plt.close()
    print(f"Saved plot: {outname}")

plot_consensus_linegraphs(df_long_consensus, "TRAIN", "Training", "LineGraphs_TRAIN_Consensus_Average.png")
